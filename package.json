{
  "name": "vozilo-ba",
  "private": true,
  "version": "0.1.0",
  "description": "Vehicle management platform and automotive community for Bosnia and Herzegovina.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @vozilo/frontend",
    "dev:frontend": "npm run dev --workspace @vozilo/frontend",
    "dev:backend": "npm run start:dev --workspace @vozilo/backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
