generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlan {
  FREE
  PREMIUM
  BUSINESS
}

enum MaintenanceCategory {
  OIL_CHANGE
  TIMING_BELT
  DSG_SERVICE
  BRAKES
  TIRES
  BATTERY
  CUSTOM
}

enum ExpenseCategory {
  FUEL
  SERVICE
  INSURANCE
  REGISTRATION
  TIRES
  OTHER
}

enum WorkshopCategory {
  MECHANIC
  AUTO_ELECTRICIAN
  BODY_SHOP
  TIRE_SHOP
  DIAGNOSTICS
  AIR_CONDITIONING
  AUTHORIZED_SERVICE
}

model User {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  email        String    @unique
  passwordHash String?
  googleId     String?   @unique
  name         String?
  locale       String    @default("bs")
  plan         UserPlan  @default(FREE)
  trialEndsAt  DateTime?
  vehicles     Vehicle[]
  topics       ForumTopic[]
  replies      ForumReply[]
}

model Vehicle {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  ownerId        String
  owner          User      @relation(fields: [ownerId], references: [id])
  make           String
  model          String
  productionYear Int
  engine         String
  vin            String?
  licensePlate   String?
  currentMileage Int
  maintenance    MaintenanceRecord[]
  expenses       Expense[]
  reminders      Reminder[]

  @@index([ownerId])
  @@index([make, model])
  @@index([vin])
}

model MaintenanceRecord {
  id          String              @id @default(uuid())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  vehicleId   String
  vehicle     Vehicle             @relation(fields: [vehicleId], references: [id])
  category    MaintenanceCategory
  title       String
  description String?
  mileage     Int
  servicedAt  DateTime
  cost        Decimal?            @db.Decimal(10, 2)

  @@index([vehicleId, servicedAt])
}

model Expense {
  id          String          @id @default(uuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id])
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  occurredAt  DateTime
  description String?

  @@index([vehicleId, occurredAt])
}

model Reminder {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  title       String
  dueAt       DateTime?
  dueMileage  Int?
  completedAt DateTime?

  @@index([vehicleId, dueAt])
}

model Workshop {
  id                  String             @id @default(uuid())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  name                String
  city                String
  address             String?
  category            WorkshopCategory
  brandSpecialization String[]
  latitude            Decimal?           @db.Decimal(9, 6)
  longitude           Decimal?           @db.Decimal(9, 6)
  isFeatured          Boolean            @default(false)
  reviews             Review[]

  @@index([city])
  @@index([category])
  @@index([brandSpecialization])
}

model Review {
  id         String    @id @default(uuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  workshopId String
  workshop   Workshop  @relation(fields: [workshopId], references: [id])
  rating     Int
  comment    String?

  @@index([workshopId])
  @@index([rating])
}

model ForumTopic {
  id        String       @id @default(uuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  brand     String
  model     String
  title     String
  body      String
  votes     Int          @default(0)
  replies   ForumReply[]

  @@index([brand, model])
  @@index([createdAt])
  @@index([votes])
}

model ForumReply {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  topicId   String
  topic     ForumTopic @relation(fields: [topicId], references: [id])
  authorId  String
  author    User       @relation(fields: [authorId], references: [id])
  body      String
  votes     Int        @default(0)

  @@index([topicId])
}

model VehicleIssue {
  id                  String    @id @default(uuid())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  make                String
  model               String
  productionYearStart Int?
  productionYearEnd   Int?
  title               String
  description         String
  estimatedCostMin    Decimal?  @db.Decimal(10, 2)
  estimatedCostMax    Decimal?  @db.Decimal(10, 2)
  votes               Int       @default(0)

  @@index([make, model])
  @@index([votes])
}

model AuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
}
